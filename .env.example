# Database
DATABASE_URL=postgres://rally:rally@localhost:5433/rally?sslmode=disable

# Slack
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret
# Slack OAuth (for workspace install flow at /slack/install)
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=http://localhost:8432/slack/oauth/callback

# LLM Providers
# Greenthread (default LLM provider — OpenAI-compatible, endpoint: https://api.us-west-2.ai.amaze.au/v1)
GREENTHREAD_API_KEY=sk-your-greenthread-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# GitHub
GITHUB_TOKEN=ghp_your-token-here

# Server
# Dev server port — must match templ proxy target in Taskfile.yml
PORT=8432
APP_NAME=rally

# AE Container Runtime
# Host path where per-company workspace files are stored (bind-mounted into AE containers).
# Must be writable by the current user. On macOS, avoid /var — use a local project path.
RALLY_WORKSPACE_ROOT=/path/to/rally/.workspaces
# URL that AE containers use to reach the Rally server.
# Use http://host.docker.internal:8432 for local dev (Docker Desktop).
# In production, set to the internal/service URL reachable from the container network.
RALLY_API_URL=http://host.docker.internal:8432

# DB URI for Taskfile tasks
DB_URI=postgres://rally:rally@localhost:5433/rally?sslmode=disable

# Vault encryption removed — credentials stored plaintext in DB.
# The database itself is the security boundary.

# Google OAuth2 (for Google Workspace tool)
# Required scopes: gmail.send, gmail.readonly, documents, drive.file,
#   calendar, calendar.events (calendar scopes required for SDR meeting booking)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8432/oauth/google/callback

# Figma (for Designer-AE)
# Use Personal Access Token from Figma > Account > Personal access tokens
FIGMA_PERSONAL_ACCESS_TOKEN=figd_your-token-here
# Or OAuth2 (preferred for multi-user):
FIGMA_CLIENT_ID=your-figma-client-id
FIGMA_CLIENT_SECRET=your-figma-client-secret
